{
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/*.css",
          "/*.js",
          "/manifest.webmanifest"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(png|jpg|jpeg|svg|webp|gif)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "moods-api",
      "urls": [
        "/moods",
        "/moods/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 60,
        "maxAge": "24h",
        "timeout": "5s"
      }
    },
    {
      "name": "habits-api",
      "urls": [
        "/habits",
        "/habits/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 60,
        "maxAge": "24h",
        "timeout": "5s"
      }
    },
    {
      "name": "journals-api",
      "urls": [
        "/journals",
        "/journals/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 60,
        "maxAge": "24h",
        "timeout": "5s"
      }
    }
  ]
}
